#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SERVICE
#=================================================
ynh_script_progression "Stopping $app..."

ynh_systemd_action --service_name="$app" --action="stop"

#=================================================
# UPDATE SOURCE FILES
#=================================================
ynh_script_progression "Updating application files..."

cp "$YNH_APP_BASEDIR/sources/extra_files/app/app.py"           "$install_dir/app.py"
cp "$YNH_APP_BASEDIR/sources/extra_files/app/requirements.txt" "$install_dir/requirements.txt"
cp "$YNH_APP_BASEDIR/sources/extra_files/app/index.html"       "$install_dir/static/index.html"

"$install_dir/venv/bin/pip" install --upgrade -r "$install_dir/requirements.txt"

chown -R "$app:www-data" "$install_dir"
chmod -R o-rwx "$install_dir"
chown -R "$app:$app" "$install_dir/venv"

#=================================================
# REGENERATE ENV FILE
#=================================================
ynh_script_progression "Updating environment file..."

app_secret=$(ynh_app_setting_get --key=app_secret)

cat > "$install_dir/env" << EOF
PORT=$port
DATA_DIR=$data_dir
ADMIN_USER=$admin
APP_SECRET=$app_secret
EOF

chmod 600 "$install_dir/env"
chown "$app:$app" "$install_dir/env"

#=================================================
# UPDATE SYSTEMD AND NGINX
#=================================================
ynh_script_progression "Updating systemd and nginx configuration..."

ynh_add_systemd_config
ynh_add_nginx_config

#=================================================
# RESTART SERVICE
#=================================================
ynh_script_progression "Restarting $app..."

ynh_systemd_action --service_name="$app" --action="restart" --log_path="systemd" --line_match="Running on"

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression "Upgrade of $app completed"
